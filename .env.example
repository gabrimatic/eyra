API_BASE_URL=http://localhost:11434/v1
API_KEY=ollama

# Local development smoke tests without a running backend.
USE_MOCK_CLIENT=false

# Default model for all requests when complexity routing is off.
MODEL=gemma4:e4b
# Vision model for screen/image tasks. Empty means use MODEL.
VISION_MODEL=

# Model recovery.
AUTO_PULL_MODELS=true

# Voice and speech.
LIVE_LISTENING_ENABLED=true
LIVE_SPEECH_ENABLED=true
SPEECH_COOLDOWN_MS=3000
VOICE_INPUT_DEVICE=
VOICE_SAMPLE_RATE=16000
VOICE_DEBUG_RECORD_SECONDS=3
VOICE_DIAGNOSTIC_SAVE_AUDIO=false
VOICE_SILENCE_MS=1500
VOICE_VAD_THRESHOLD=0.15

# Background task coordinator. Keeps input responsive while long work continues.
BACKGROUND_TASKS_ENABLED=true
MAX_BACKGROUND_TASKS=2
# Optional worker model override. Empty means use MODEL.
WORKER_MODEL=
TASK_TIMEOUT_SECONDS=300
MAX_WORKER_TOOL_STEPS=8
TOOL_TIMEOUT_SECONDS=30
MODEL_CONCURRENCY=1
TASK_STATUS_UPDATES=true
# Local SQLite store for durable jobs, logs, and operation ledger.
JOB_STORE_PATH=~/.local/share/eyra/jobs.sqlite3
# Local SQLite store for user-created trigger definitions and status.
TRIGGER_STORE_PATH=~/.local/share/eyra/triggers.sqlite3
# Explicit file triggers are bounded. They do not run unless the user creates one.
TRIGGER_CHECK_INTERVAL_SECONDS=0.5
TRIGGER_TIMEOUT_SECONDS=300

# Optional network tools. Keep false for the local-first default.
# When true, weather and browser tools can contact remote sites on demand.
NETWORK_TOOLS_ENABLED=false

# Optional OS/operator tools. Disabled by default.
OS_TOOLS_ENABLED=false
# Optional local OCR command for screen text extraction. Must read PNG bytes from stdin.
SCREEN_OCR_COMMAND=

# Optional external agent bridges. Disabled by default.
AGENT_TOOLS_ENABLED=false
# Optional configured external-agent adapters. Static argv only, sandboxed cwd.
EXTERNAL_AGENT_TOOLS_ENABLED=false
EXTERNAL_AGENT_CONFIG_PATH=~/.config/eyra/agents.json

# Optional universal connectors. Disabled by default.
# Connectors are static manifests for external workers under Eyra policy.
CONNECTORS_ENABLED=false
CONNECTORS_CONFIG_PATH=~/.config/eyra/connectors.json
# Empty means use FILESYSTEM_ALLOWED_PATHS.
CONNECTORS_ALLOWED_ROOTS=
CONNECTORS_TIMEOUT_SECONDS=600
CONNECTORS_OUTPUT_CAP_BYTES=32768
CONNECTORS_ALLOW_REMOTE=false
CONNECTORS_ALLOW_PYTHON_MODULE=false

# Optional stdio MCP bridge. Disabled by default.
MCP_TOOLS_ENABLED=false
MCP_CONFIG_PATH=~/.config/eyra/mcp.json

# Optional Web UI. Localhost by default.
WEB_UI_ENABLED=false
WEB_UI_HOST=127.0.0.1
WEB_UI_PORT=8765
# Empty means Eyra generates a session token at startup.
WEB_UI_TOKEN=
# auto = token required for all non-health API endpoints. false is allowed only on localhost.
WEB_UI_REQUIRE_TOKEN=auto
# Applies to chat requests, task APIs, and browser audio uploads.
WEB_UI_MAX_REQUEST_BYTES=1000000

# Optional online Realtime voice. Disabled by default.
REALTIME_VOICE_ENABLED=false
REALTIME_MODEL=gpt-realtime
REALTIME_VOICE=marin
# Realtime requires an OpenAI API key and never reuses generic API_KEY.
OPENAI_API_KEY=
# Realtime tools are off by default because tool outputs may leave the machine.
REALTIME_TOOLS_ENABLED=false
REALTIME_ALLOWED_TOOLS=

# Filesystem tool: comma-separated allowed root paths (~ is expanded).
# Default: ~/Documents,~/Desktop,~/Downloads,/tmp. The model can access only these directories.
# Add paths only when the workflow needs them: ~/Documents,~/Desktop,~/Downloads,/tmp,/Volumes/Data
FILESYSTEM_ALLOWED_PATHS=~/Documents,~/Desktop,~/Downloads,/tmp

# Filesystem tool: default working directory for relative paths (~ is expanded).
# Relative paths resolve here, then pass through FILESYSTEM_ALLOWED_PATHS.
# FILESYSTEM_DEFAULT_PATH=~/Documents

# Optional model-tier routing.
# When enabled, Eyra selects model tiers by prompt complexity. This is not a safety boundary:
# tool policy, sandboxing, approvals, and opt-in settings still decide what can run.
# COMPLEXITY_ROUTING_ENABLED=true
# SIMPLE_MODEL=qwen3.5:2b
# MODERATE_MODEL=gemma4:e4b

# Local policy routing is always on. It is deterministic and local; it does not
# call a model, embeddings, telemetry, analytics, or a network router.
ROUTING_DEBUG=false

# Optional hands-free mode marker. Spoken control phrases work in normal mode too;
# this flag makes the intended no-hands runtime state visible in status/capabilities.
HANDS_FREE_MODE=false
