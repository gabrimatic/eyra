OLLAMA_HOST=localhost
OLLAMA_PORT=11434

# Set to true to run without any AI backend (development only)
USE_MOCK_CLIENT=false

# Screenshot interval for Live mode (seconds)
SCREENSHOT_INTERVAL=1

# Model overrides (optional, defaults shown)
# SIMPLE_TEXT_MODEL=qwen3.5:2b-q4_K_M
# MODERATE_TEXT_MODEL=qwen3.5:4b-q4_K_M
# SIMPLE_IMAGE_MODEL=qwen3.5:2b-q4_K_M
# MODERATE_IMAGE_MODEL=qwen3.5:4b-q4_K_M
# COMPLEX_MODEL=qwen3.5:9b-q4_K_M
