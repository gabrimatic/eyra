API_BASE_URL=http://localhost:11434/v1
API_KEY=ollama

# Set true for local development smoke tests without a running backend.
USE_MOCK_CLIENT=false

# Default model (used for all requests when complexity routing is off)
MODEL=gemma3:4b

# Model recovery
AUTO_PULL_MODELS=true

# Voice and speech
LIVE_LISTENING_ENABLED=true
LIVE_SPEECH_ENABLED=true
SPEECH_COOLDOWN_MS=3000
VOICE_SILENCE_MS=1500
VOICE_VAD_THRESHOLD=0.6

# Optional network tools. Keep false for fully local default behavior.
# When true, weather and browser tools may contact remote sites on demand.
NETWORK_TOOLS_ENABLED=false

# Filesystem tool: comma-separated allowed root paths (~ is expanded)
# Default: ~/Documents,/tmp - the model can only access files under these directories.
# Add more paths to grant access: ~/Documents,/tmp,/Volumes/Data,/opt/projects
FILESYSTEM_ALLOWED_PATHS=~/Documents,/tmp

# Filesystem tool: default working directory for the model (~ is expanded)
# Relative file paths are resolved here, then checked against FILESYSTEM_ALLOWED_PATHS.
# FILESYSTEM_DEFAULT_PATH=~/Documents

# Experimental: complexity-based model routing
# When enabled, routes requests to different model tiers based on prompt complexity.
# COMPLEXITY_ROUTING_ENABLED=true
# SIMPLE_MODEL=qwen3.5:2b
# MODERATE_MODEL=gemma3:4b
